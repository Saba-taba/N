            document.body.appendChild(heart);
            setTimeout(() => heart.remove(), 3000);
        }
        
        setInterval(createSnow, 800);
        setInterval(createFloatingHeart, 1100);
        
        // ========== INITIALIZE ALL ==========
        renderMap();
        renderCalendar();
        buildHeartGame();
        initMemoryGame();
        renderPuzzle();
        renderTreasure();
    </script>
</body>
</html>
